          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "sortBy": "Total", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Log Volume by Server",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (server) (count_over_time({server=~\"$server\", job=~\"$job\"} |~ \"$search\" [$__interval]))",
          "legendFormat": "{{ server }}",
          "refId": "A"
        }
      ]
    },
