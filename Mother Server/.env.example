# ─── Central Hub Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.

# Domain pointing at this server (must have a DNS A record)
DOMAIN=grafana.mdrezaulkarim.com

# Grafana admin credentials (change immediately after first login)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme_strong_password

# Basic-auth credentials for agent push endpoints (must match agent .env)
AGENT_AUTH_USER=agent_user
AGENT_AUTH_PASS=changeme_agent_password

# Prometheus data retention (adjust based on available disk)
PROMETHEUS_RETENTION=30d

# Alertmanager webhook URL (Power Automate / Teams / Slack / etc.)
ALERTMANAGER_WEBHOOK_URL="https://defaultaf6eded8005446a784d4bb425fd9fb.5a.environment.api.powerplatform.com:443/powerautomate/automations/direct/cu/19/workflows/f4cf41c0d7f7433fa1f4ab8ac4dac59f/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=5ubHPjhSnhWx5C3CfT1dg-pucabK4vuy0TMilL_a7Mg"
